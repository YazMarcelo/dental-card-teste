# URL base do projeto dental-card (FastAPI / lang-atendente).
# Sem barra no final.
DENTAL_CARD_URL=https://sorria-goias-lang-dental-card.rd5zte.easypanel.host

# Token do header X-Webhook-Token (== WEBHOOK_SECRET do dental-card).
DENTAL_CARD_TOKEN=troque-este-token

# Slug da clínica cadastrada no dental-card (multi-tenant).
CLINICA_SLUG=sorria-garavelo

# Banco Postgres do dental-card (o MESMO usado pelo lang-atendente).
# Usado pra ler o histórico de conversa e os leads com agendamento (confirmação).
# Formato: postgresql://usuario:senha@host:5432/banco
DENTAL_CARD_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lang_atendente
# Se o banco exigir SSL (ex.: provedor externo), deixe "true".
DENTAL_CARD_DB_SSL=false

# Nome de exibição da clínica — usado só pra renderizar o {{clinica}} dos templates
# na tela. Pode ser público.
NEXT_PUBLIC_CLINIC_NAME=Vamos Sorrir - Porto Velho
